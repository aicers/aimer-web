# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/postgres

# Migration runner (owner role — full DDL + DML privileges)
DATABASE_MIGRATION_URL=postgres://aimer_auth_owner:changeme@localhost:5432/auth_db
AUDIT_DATABASE_MIGRATION_URL=postgres://aimer_audit_owner:changeme@localhost:5432/audit_db
CUSTOMER_DATABASE_OWNER_URL=postgres://aimer_customer_owner:changeme@localhost:5432/template1

# Application runtime (restricted role — minimum required privileges)
DATABASE_URL=postgres://aimer_auth:changeme@localhost:5432/auth_db
AUDIT_DATABASE_URL=postgres://aimer_audit:changeme@localhost:5432/audit_db
CUSTOMER_DATABASE_URL=postgres://aimer_customer:changeme@localhost:5432/template1

# ---------------------------------------------------------------------------
# OpenBao (Vault-compatible secret management)
# ---------------------------------------------------------------------------
BAO_ADDR=http://localhost:8200
# Auto-generated on first `docker compose --profile dev up`.
# Retrieve with: docker compose exec openbao cat /bao/init/keys.json
BAO_TOKEN=

# ---------------------------------------------------------------------------
# Keycloak (Identity & Access Management)
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# BFF → Keycloak URL used for server-to-server discovery and token
# exchange. Distinct from KC_HOSTNAME, which is Keycloak's view of its
# own public URL. The default `http://localhost:8080` is the dev value.
# The bundled prod profile must use the internal compose address
# `http://keycloak-prod:8080` (no path suffix, since the prod profile
# leaves KC_HTTP_RELATIVE_PATH=/). If KC_HTTP_RELATIVE_PATH is
# customized, the path component of KEYCLOAK_URL must match it.
#
# Do NOT point this at the public proxy URL (e.g. the value of
# KC_HOSTNAME). With KC_HOSTNAME_BACKCHANNEL_DYNAMIC=true (forced by
# the prod profile) Keycloak then emits a split discovery document —
# frontchannel URLs carry the `/auth` prefix but backchannel URLs
# (token_endpoint, jwks_uri) do not — and the BFF token exchange POSTs
# to a path that nginx routes to next-app, breaking sign-in.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aimer

# General OIDC client
OIDC_GENERAL_CLIENT_ID=aimer-web
OIDC_GENERAL_CLIENT_SECRET=changeme-general-secret

# System Admin OIDC client
OIDC_ADMIN_CLIENT_ID=aimer-web-admin
OIDC_ADMIN_CLIENT_SECRET=changeme-admin-secret
ADMIN_ACCEPTED_ACR_VALUES=urn:keycloak:acr:mfa,urn:keycloak:acr:2fa
ADMIN_MAX_AUTH_AGE_SECONDS=300

# Keycloak Admin API (service account for realm role management)
# Required for admin designation / revocation (POST/DELETE /api/admin/admins).
# Create a dedicated confidential client in Keycloak with Service Account
# enabled and the "realm-admin" role assigned to its service account.
# Do NOT use "admin-cli" — it does not support client_credentials by default.
KEYCLOAK_ADMIN_CLIENT_ID=aimer-admin-sa
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme-admin-sa-secret

# Production Keycloak database
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=changeme

# Production Keycloak hostname (prod profile only). REQUIRED — `docker compose
# --profile prod up` refuses to start without it. Must be the canonical public
# URL operators want in OIDC URLs (issuer, redirect_uri, account console,
# password-reset links). The scheme is required because the prod profile
# also sets KC_HOSTNAME_BACKCHANNEL_DYNAMIC=true, which Keycloak 26 rejects
# unless KC_HOSTNAME is a full URL. Include the public path your reverse
# proxy mounts Keycloak under (the bundled `nginx-prod` mounts it at /auth);
# whatever path is here becomes the prefix on every browser-facing OIDC URL.
# No query, no trailing slash.
# Examples:
#   KC_HOSTNAME=https://aimer-web.example.com/auth     # bundled nginx-prod
#   KC_HOSTNAME=https://aimer-web.example.com          # Keycloak at the apex
#   KC_HOSTNAME=https://auth.aimer-web.example.com     # dedicated host
KC_HOSTNAME=

# Path prefix the Keycloak process itself listens on (NOT the public path
# from KC_HOSTNAME). Leave at `/` when the reverse proxy strips the public
# prefix before proxying — the bundled `nginx-prod` strips `/auth/`, so
# Keycloak still receives `/`. Set to `/auth` (or another prefix) only when
# the proxy preserves the prefix end-to-end. The prod healthcheck appends
# this when probing the OIDC discovery endpoint.
KC_HTTP_RELATIVE_PATH=/

# Social login (disabled by default — set to enable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# mTLS (mutual TLS for backend service communication)
# ---------------------------------------------------------------------------
MTLS_CERT_PATH=
MTLS_KEY_PATH=
MTLS_CA_PATH=

# ---------------------------------------------------------------------------
# GraphQL
# ---------------------------------------------------------------------------
AIMER_GRAPHQL_ENDPOINT=

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# ---------------------------------------------------------------------------
# Backup & Restore
# ---------------------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
AUDIT_BACKUP_RETENTION_DAYS=365
# Path to OpenBao file-storage directory (required for OpenBao backup)
BAO_DATA_DIR=

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Filesystem directory next-app reads (and in dev writes) the session JWT
# signing key pair from (`${DATA_DIR}/keys/ec-{private,public}.pem` — PKCS8
# private, SPKI public, ES256). In dev these are auto-generated on first
# start. In production the BFF refuses to start if the files are missing —
# operators must seed `${DATA_DIR}/keys/` with a pre-generated pair before
# traffic reaches next-app. See docs/en/configuration.md "Session JWT key
# persistence" for the pre-generation recipe. The prod compose profile
# overrides this to `/app/data` and binds the `next-app-data` named volume
# there. For local dev the default `./data` is fine.
DATA_DIR=./data
JWT_EXPIRATION_MINUTES=15
CSRF_SECRET=
INIT_ADMIN_USERNAME=
INIT_ADMIN_PASSWORD=
DEFAULT_LOCALE=ko

# Public URL of the deployed user manual (mkdocs site).
# Used to link to operations guides from in-app inline help.
# Leave unset to fall back to the GitHub Pages location.
NEXT_PUBLIC_MANUAL_BASE_URL=

# Public canonical origin of the deployed BFF. Required in production
# when the BFF runs behind a reverse proxy (the default prod compose
# path), because Next.js cannot infer the public origin from forwarded
# headers and would otherwise emit OIDC redirect_uri / absolute redirects
# pointing at the container-internal bind hostname (e.g. 0.0.0.0:3000).
# A trailing slash is allowed and is normalised away. Path, query, and
# hash components are rejected at server startup.
#   EXPECTED_ORIGIN=https://aimer-web.example.com        # allowed
#   EXPECTED_ORIGIN=https://aimer-web.example.com/       # allowed, normalised
#   EXPECTED_ORIGIN=https://aimer-web.example.com/foo    # rejected (path)
#   EXPECTED_ORIGIN=https://aimer-web.example.com?x=1    # rejected (query)
EXPECTED_ORIGIN=

# ---------------------------------------------------------------------------
# AI analysis worker (RFC 0002)
# ---------------------------------------------------------------------------
# Default variant used by the story-analysis worker and the regenerate /
# summary endpoints when no `lang` / `model_name` / `model` is supplied.
ANALYSIS_DEFAULT_LANG=ENGLISH
ANALYSIS_DEFAULT_MODEL_NAME=openai
ANALYSIS_DEFAULT_MODEL=gpt-4o

# Analyst-facing model allow-list (#458) offered by the regenerate model
# picker and the side-by-side compare view. JSON array of
# `{ modelName, model, label }` objects, in display order. The configured
# default pair (`ANALYSIS_DEFAULT_MODEL_NAME` / `ANALYSIS_DEFAULT_MODEL`) is
# always present even if absent here (prepended if missing); entries are
# deduped by `(modelName, model)` with the first occurrence winning. Malformed
# JSON or an entry missing `modelName`/`model` falls back to the default pair
# only. UI-side allow-list only — the regenerate endpoints stay tolerant of
# their existing inputs.
# Example:
#   ANALYSIS_MODEL_CATALOG=[{"modelName":"openai","model":"gpt-4o","label":"OpenAI GPT-4o"},{"modelName":"anthropic","model":"claude-3-5-sonnet","label":"Anthropic Claude 3.5 Sonnet"}]
ANALYSIS_MODEL_CATALOG=

# Phase 1 (#296) worker tunables.
#  * `WORKER_ACCOUNT_ID` is the JWT `sub` aimer sees for background
#     analysis calls; reserved value, not a real account UUID.
#  * `RETRY_BACKOFF_BASE_MS` / `RETRY_BACKOFF_MAX_MS` shape the exponential
#     backoff predicate used by the dispatcher: after `attempts=1` the row
#     waits BASE ms; the exponent caps at log2(MAX/BASE).
#  * `MAX_ATTEMPTS` is the auto-queued retry cap; the Nth failed attempt
#     moves the job to `status='failed'`. Force-queued jobs reset to 0.
#  * `PROCESSING_TIMEOUT_MINUTES` is the watchdog timeout — `processing`
#     rows older than this flip back to `queued`.
#  * `LIKELIHOOD_MEMBER_COUNT_FLOOR_N` is the canonical-version member
#     count above which the likelihood floor of 0.7 applies.
#  * `MAX_GENERATION` caps automatic dirty re-queues per
#     `(customer_id, story_id, variant)` (RFC 0002 guardrail). When a
#     dirty state row's existing default-variant job already sits at
#     this generation, the seeding pass emits the
#     `analysis.story_max_generation_reached` log line and flips the
#     row back to `ready` without enqueuing a new job — operators can
#     still force past the cap via `POST /analysis/story/.../regenerate`.
#     If a dirty row has no default-variant job at all (e.g. right after
#     the Phase 1 dry-run-purge migration), the seeding pass instead
#     inserts a fresh generation 1 job; the cap only applies to bumps
#     of an existing job, not to seeding a first-ever real job.
ANALYSIS_WORKER_ACCOUNT_ID=system:analysis-worker
ANALYSIS_RETRY_BACKOFF_BASE_MS=30000
ANALYSIS_RETRY_BACKOFF_MAX_MS=900000
ANALYSIS_MAX_ATTEMPTS=5
ANALYSIS_PROCESSING_TIMEOUT_MINUTES=30
ANALYSIS_LIKELIHOOD_MEMBER_COUNT_FLOOR_N=5
ANALYSIS_MAX_GENERATION=50

# RFC 0002 Phase 2 (#297) — periodic report worker.
#   ANALYSIS_PERIODIC_WORKER_AICE_ID: sentinel aice_id stamped on the
#     mTLS request actor for cross-aice periodic reports (the report
#     aggregates across multiple AICE environments, so there is no
#     canonical aice_id). aimer authorization is stateless and treats
#     aice_id as informational, but the value must be stable so aimer-side
#     audit rows stay comparable.
#   ANALYSIS_LIVE_REFRESH_MINUTES: per-variant LIVE re-queue cadence; a
#     done LIVE job is re-queued once NOW() >= last_generated_at + this.
#   ANALYSIS_REPORT_TOP_STORIES_K / _TOP_EVENTS_K: input-builder caps on
#     how many top stories / single events a report cites.
#   ANALYSIS_BASELINE_DRIFT_NOISE_THRESHOLD: fractional per-category delta
#     vs the prior period above which baseline drift is treated as a
#     high-confidence (likelihood 1.0) signal rather than noise.
ANALYSIS_PERIODIC_WORKER_AICE_ID=system:periodic-report
ANALYSIS_LIVE_REFRESH_MINUTES=60
ANALYSIS_REPORT_TOP_STORIES_K=5
ANALYSIS_REPORT_TOP_EVENTS_K=10
ANALYSIS_BASELINE_DRIFT_NOISE_THRESHOLD=0.3
